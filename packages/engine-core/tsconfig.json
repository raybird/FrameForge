{
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@frameforge/shared-types": ["../shared-types/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src", "vitest.config.ts"]
}

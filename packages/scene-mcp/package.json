{
  "name": "@frameforge/scene-mcp",
  "version": "0.1.0",
  "description": "FrameForge 場景生成的 MCP 工具伺服器（get_scene_schema / compile_scene / validate_scene / save_scene）",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "frameforge-scene-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "node build.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
